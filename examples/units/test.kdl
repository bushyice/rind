service {
  name "test"
  run {
    exec "/bin/tcp"
    args "makano-test"
  }
  space "user"
  user-source {
    state "rind:user_session"
    username-field "username"
  }
  start-on {
    state "rind:user_session"
  }
}

service {
  name "something"
  run {
    exec "/bin/tcp"
    args "makano-test"
    env {
      PORT "4433"
    }
  }
  space "user"
  user-source {
    state "rind:user_session"
    username-field "username"
  }
}

service {
  name "many"
  run {
    exec "/bin/tcp"
    args "makano-test"
    env {
      PORT "4533"
    }
  }
  space "user"
  start-on {
    state "rind:user_session"
  }
  start-on {
    state "rind:net-configured"
  }
  user-source {
    state "rind:user_session"
    username-field "username"
  }
}

variable {
  name "someservice"
  default {
    exec "/bin/tcp"
    args "makano-test"
    env {
      PORT "4533"
    }
  }
}

signal {
  name "thething"
  payload "string"
}

service {
  name "ipcs"
  run {
    exec "/bin/ipc_so"
    args "makano-test"
  }
  start-on {
    signal "test:thething"
  }
}

socket {
  name "ipcs_s"
  type "uds"
  listen "/var/sock/some.sock"
  owner "test:ipcs"
  start-on {
    state "net:configured"
  }
  trigger {
    - {
      signal "test:thething"
      payload "()"
    }
  }
}

service {
  name "sif"
  run {
    exec "/bin/sif"
  }
  transport "stdio"
  start-on {
    signal "rind:boot"
  }
  restart #false
  cgroup {
    path "/sys/fs/cgroup/rind-demo/sif"
    memory-max "128M"
    cpu-max "50000 100000"
    pids-max "64"
  }
  namespaces {
    mount #true
    uts #true
    ipc #true
    net #true
    cgroup #true
  }
  watchdog {
    interval-ms 1000
    grace-ms 5000
    action "restart"
  }
}
